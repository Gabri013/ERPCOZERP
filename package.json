{
  "name": "erpcozerp",
  "private": true,
  "version": "1.0.0",
  "description": "ERP Cozinha — monorepo (apps/frontend + apps/backend)",
  "scripts": {
    "dev": "concurrently -n fe,be -c cyan,magenta \"npm run dev --prefix apps/frontend\" \"npm run dev --prefix apps/backend\"",
    "dev:frontend": "npm run dev --prefix apps/frontend",
    "dev:backend": "npm run dev --prefix apps/backend",
    "build": "npm run build --prefix apps/frontend && npm run build --prefix apps/backend",
    "lint": "npm run lint --prefix apps/frontend && npm run lint --prefix apps/backend",
    "lint:frontend": "npm run lint --prefix apps/frontend",
    "lint:backend": "npm run lint --prefix apps/backend",
    "smoke": "npm run lint --prefix apps/backend && npm run build --prefix apps/frontend",
    "test:smoke": "node tests/smoke/test-all-endpoints.cjs",
    "test:smoke:core": "node tests/smoke/smoke-test-core.cjs",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm run test --prefix apps/backend",
    "test:frontend": "npm run test --prefix apps/frontend",
    "test:backend:coverage": "npm run test:coverage --prefix apps/backend",
    "test:frontend:coverage": "npm run test:coverage --prefix apps/frontend",
    "test:coverage": "npm run test:backend:coverage && npm run test:frontend:coverage",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=\"Desktop Chrome\"",
    "test:e2e:tablet": "playwright test --project=Tablet",
    "test:e2e:mobile": "playwright test --project=\"Mobile Safari\"",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report test-reports/playwright",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:auth": "playwright test tests/e2e/auth",
    "test:e2e:navigation": "playwright test tests/e2e/navigation",
    "test:e2e:sales": "playwright test tests/e2e/sales",
    "test:e2e:production": "playwright test tests/e2e/production",
    "test:e2e:performance": "playwright test tests/e2e/performance",
    "test:all": "npm run test && npm run test:e2e",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:seed": "docker compose run --rm -e SEED_ENABLED=true backend npm run prisma:seed",
    "sync:cozinca-team": "npm run sync:cozinca-team --prefix apps/backend",
    "migrate:legacy": "node scripts/migrate-legacy-data.js",
    "seed:materials": "node scripts/seed-raw-materials.js"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3"
  }
}
