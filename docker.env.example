# Opcional: só necessário se usar `docker compose` (stack em containers).
# Copie para ".env" na raiz (mesma pasta que docker-compose.yml).

FRONTEND_URL=http://localhost:5173
JWT_SECRET=substitua_por_string_longa_aleatoria_minimo_32_caracteres
SEED_ENABLED=true
DEFAULT_MASTER_PASSWORD=defina_senha_forte
DEFAULT_ADMIN_PASSWORD=defina_senha_forte

# Após o primeiro deploy com dados, defina:
# SEED_ENABLED=false

# Email (Resend — https://resend.com — plano free: 3000 emails/mês)
RESEND_API_KEY=           # obtenha em resend.com/api-keys
EMAIL_FROM=ERP Cozinca <erp@cozinca.com.br>
