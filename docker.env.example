# Copie para ".env" na raiz do repositório (mesma pasta que docker-compose.yml).
# O Docker Compose usa esse ficheiro para substituir ${VARIÁVEL} no compose.

FRONTEND_URL=http://localhost:5173
JWT_SECRET=substitua_por_string_longa_aleatoria_minimo_32_caracteres
SEED_ENABLED=true
DEFAULT_MASTER_PASSWORD=defina_senha_forte
DEFAULT_ADMIN_PASSWORD=defina_senha_forte

# Após o primeiro deploy com dados, defina:
# SEED_ENABLED=false
