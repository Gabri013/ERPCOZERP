# Copie para .env na raiz e ajuste. Usado por scripts na raiz e espelhamento de secrets.
# O Docker Compose (opcional) também lê este ficheiro se usar `docker compose`.

# Obrigatório em produção / compose (use valor forte e aleatório)
JWT_SECRET=change_me_use_long_random_string_min_32_chars

# API exposta no host (padrão 3001)
# BACKEND_PUBLISH_PORT=3001

# SPA nginx exposto no host (padrão 5173)
# FRONTEND_PUBLISH_PORT=5173

# Postgres exposto no host (padrão 5432 — pode conflitar com Postgres local)
# POSTGRES_PUBLISH_PORT=5432
POSTGRES_PASSWORD=erpcozpass

# Backend / Prisma / scripts rodando no host (Postgres do compose em localhost).
# Se não definir, `npm run sync:cozinca-team` usa estes mesmos valores como fallback (somente fora de production).
# DATABASE_URL=postgresql://erpcoz:erpcozpass@127.0.0.1:5432/erpcoz

# Redis exposto no host (padrão 6379)
# REDIS_PUBLISH_PORT=6379

# URLs / seed
FRONTEND_URL=http://localhost:5173
JWT_EXPIRES_IN=7d
DEFAULT_MASTER_PASSWORD=master123_dev
SEED_ENABLED=true

# Frontend dev (opcional): proxy Vite para API
# VITE_BACKEND_URL=http://127.0.0.1:3001
