{
  "version": 2,
  "builds": [
    {
      "src": "apps/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://erp-backend-production-373b.up.railway.app/api/$1"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "https://erp-backend-production-373b.up.railway.app/socket.io/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
