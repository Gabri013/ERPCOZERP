{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci --omit=optional --ignore-workspace-root-check",
  "framework": "vite",
  "cleanUrls": true,
  "ignoreCommand": "test -d backend && echo 'Backend folder exists - excluding from build' || exit 0",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://erp-backend-iwvv.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
