# Copie para `apps/backend/.env` ou defina na raiz do monorepo (`../../.env`).
#
# Postgres instalado no sistema (recomendado): crie usuário e base (ex. via psql/pgAdmin):
#   CREATE USER erpcoz WITH PASSWORD 'erpcozpass';
#   CREATE DATABASE erpcoz OWNER erpcoz;
#
# Se DATABASE_URL estiver ausente e NODE_ENV não for production, o script
# `sync:cozinca-team` monta a URL com defaults locais (127.0.0.1:5432, erpcoz / erpcozpass).
#
DATABASE_URL=postgresql://erpcoz:erpcozpass@127.0.0.1:5432/erpcoz
# Redis opcional no dev (recursos em fila/cache):
# REDIS_URL=redis://127.0.0.1:6379
# SKIP_OVERDUE_OP_SCAN=1
#
# Webhook Meta (stub): se definir, o POST /api/webhooks/meta exige header `x-meta-webhook-secret` igual.
# META_WEBHOOK_SECRET=
