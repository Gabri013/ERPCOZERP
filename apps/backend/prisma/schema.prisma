generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid()) @db.Uuid
  /// * Id do usuário no banco legado (MySQL/MariaDB), para migração idempotente
  legacyId                Int?                     @unique @map("legacy_id")
  email                   String                   @unique
  passwordHash            String                   @map("password_hash")
  fullName                String                   @map("full_name")
  active                  Boolean                  @default(true)
  emailVerified           Boolean                  @default(false) @map("email_verified")
  failedLoginAttempts     Int                      @default(0) @map("failed_login_attempts")
  lockedUntil             DateTime?                @map("locked_until")
  lastLoginAt             DateTime?                @map("last_login_at")
  /// * Setor operacional (ex.: Expedição, Corte Laser); opcional — usado para dashboards e filtros
  sector                  String?                  @map("sector")
  companyId               String                   @map("company_id")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  company                 Company                  @relation(fields: [companyId], references: [id])
  accessLogs              AccessLog[]
  auditLogs               AuditLog[]
  crmInboxConversations   CrmConversation[]        @relation("CrmConversationResponsible")
  crmLogs                 CrmLog[]
  dashboardLayout         DashboardLayout?
  employeeProfile         Employee?
  errorQueueReports       ErrorQueue[]
  approvedInventoryCounts InventoryCount[]         @relation("InventoryCountApprovedBy")
  approvedSaleOrders      SaleOrder[]              @relation("SaleOrderApprovedBy")
  ownedSaleOrders         SaleOrder[]              @relation("SaleOrderOwner")
  salesActivities         SalesActivity[]
  ownedOpportunities      SalesOpportunity[]       @relation("OpportunityOwner")
  stockMovements          StockMovement[]
  notifications           UserNotification[]
  permissionGrants        UserPermissionGrant[]
  roles                   UserRole[]
  sessions                UserSession[]
  workOrderStatusHistory  WorkOrderStatusHistory[]
  responsibleWorkOrders   WorkOrder[]              @relation("WorkOrderResponsible")

  @@map("users")
}

/// Fila de erros para monitorização, análise (IA) e fluxo de aprovação — não altera código em runtime.
model ErrorQueue {
  id              String    @id @default(uuid()) @db.Uuid
  /// frontend_console_error | frontend_console_warn | frontend_render | backend_exception | api_invalid | api_timeout | api_500
  type            String    @map("type") @db.VarChar(64)
  /// critical | high | medium | low
  severity        String    @map("severity") @db.VarChar(16)
  description     String    @map("description")
  /// Ficheiro ou módulo identificado (heurística / stack)
  sourceFile      String?   @map("source_file") @db.VarChar(512)
  /// pending | analyzing | fixed | ignored | review_required
  status          String    @default("pending") @map("status") @db.VarChar(32)
  route           String?   @map("route") @db.VarChar(512)
  userId          String?   @map("user_id") @db.Uuid
  stackTrace      String?   @map("stack_trace")
  httpMethod      String?   @map("http_method") @db.VarChar(16)
  httpStatus      Int?      @map("http_status")
  metadata        Json?     @map("metadata")
  analysisJson    Json?     @map("analysis_json")
  probableCause   String?   @map("probable_cause")
  suggestedFix    String?   @map("suggested_fix")
  impact          String?   @map("impact")
  autoFixEligible Boolean   @default(false) @map("auto_fix_eligible")
  autoApplied     Boolean   @default(false) @map("auto_applied")
  testResult      Json?     @map("test_result")
  rollbackAt      DateTime? @map("rollback_at") @db.Timestamptz(6)
  /// Array JSON: { at, action, detail }
  eventLog        Json      @default("[]") @map("event_log")
  pullRequestUrl  String?   @map("pull_request_url") @db.VarChar(512)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User?     @relation(fields: [userId], references: [id])

  @@index([status, createdAt], map: "idx_error_queue_status_created")
  @@index([severity, createdAt], map: "idx_error_queue_severity_created")
  @@map("error_queue")
}

/// Auditoria de eventos do CRM (Fase A — rastreabilidade para automações futuras).
model CrmLog {
  id             String   @id @default(uuid()) @db.Uuid
  eventType      String   @map("event_type")
  entityCode     String   @map("entity_code")
  entityRecordId String   @map("entity_record_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  payload        Json?
  createdAt      DateTime @default(now()) @map("created_at")
  user           User?    @relation(fields: [userId], references: [id])

  @@index([entityCode, entityRecordId], map: "idx_crm_logs_entity_record")
  @@index([createdAt], map: "idx_crm_logs_created")
  @@map("crm_logs")
}

/// Histórico de atribuição de responsáveis (CRM Fase B — automação).
model CrmAssignmentLog {
  id                String   @id @default(uuid()) @db.Uuid
  entityCode        String   @map("entity_code")
  entityRecordId    String   @map("entity_record_id") @db.Uuid
  antigoResponsavel String?  @map("antigo_responsavel")
  novoResponsavel   String   @map("novo_responsavel")
  reason            String?  @map("reason")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([entityRecordId], map: "idx_crm_assignment_record")
  @@index([entityCode, createdAt], map: "idx_crm_assignment_entity_created")
  @@map("crm_assignment_logs")
}

/// Inbox multicanal (Fase C) — conversas fora de EntityRecord.
model CrmConversation {
  id                 String       @id @default(uuid()) @db.Uuid
  channel            String       @db.VarChar(32)
  contatoNome        String       @map("contato_nome")
  contatoTelefone    String       @map("contato_telefone")
  contatoId          String?      @map("contato_id") @db.Uuid
  leadId             String?      @map("lead_id") @db.Uuid
  opportunityId      String?      @map("opportunity_id") @db.Uuid
  responsavelId      String?      @map("responsavel_id") @db.Uuid
  status             String       @default("novo") @db.VarChar(32)
  lastInboundAt      DateTime?    @map("last_inbound_at")
  lastOutboundAt     DateTime?    @map("last_outbound_at")
  lastMessageAt      DateTime?    @map("last_message_at")
  lastMessagePreview String?      @map("last_message_preview") @db.VarChar(512)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  responsavel        User?        @relation("CrmConversationResponsible", fields: [responsavelId], references: [id])
  messages           CrmMessage[]

  @@unique([channel, contatoTelefone], map: "uq_crm_conversation_channel_phone")
  @@index([status, updatedAt], map: "idx_crm_conversation_status_updated")
  @@index([responsavelId], map: "idx_crm_conversation_responsavel")
  @@map("crm_conversations")
}

model CrmMessage {
  id             String          @id @default(uuid()) @db.Uuid
  conversationId String          @map("conversation_id") @db.Uuid
  direction      String          @db.VarChar(16)
  message        String
  messageType    String          @default("text") @map("message_type") @db.VarChar(32)
  externalId     String?         @map("external_id") @db.VarChar(256)
  createdAt      DateTime        @default(now()) @map("created_at")
  conversation   CrmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt], map: "idx_crm_message_conversation_created")
  @@map("crm_messages")
}

/// Histórico de mudanças de estágio (CRM Fase D — analytics).
model CrmStageHistory {
  id             String   @id @default(uuid()) @db.Uuid
  oportunidadeId String   @map("oportunidade_id") @db.Uuid
  stageFrom      String   @map("stage_from") @db.VarChar(64)
  stageTo        String   @map("stage_to") @db.VarChar(64)
  usuarioId      String?  @map("usuario_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([oportunidadeId, createdAt], map: "idx_crm_stage_hist_opp_created")
  @@index([createdAt], map: "idx_crm_stage_hist_created")
  @@map("crm_stage_history")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  name        String
  description String?
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String                @id @default(uuid()) @db.Uuid
  code        String                @unique
  name        String
  category    String
  description String?
  type        String                @default("action")
  active      Boolean               @default(true)
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  roles       RolePermission[]
  userGrants  UserPermissionGrant[]

  @@map("permissions")
}

/// Permissões atribuídas diretamente ao usuário (somam-se às dos papéis).
model UserPermissionGrant {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  assignedBy   String?    @map("assigned_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId], map: "uq_user_permission_grant")
  @@index([userId], map: "idx_user_permission_grant_user")
  @@map("user_permission_grants")
}

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedBy String?  @map("assigned_by") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId], map: "uq_user_role")
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  granted      Boolean    @default(true)
  conditions   Json?
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId], map: "uq_role_permission")
  @@map("role_permissions")
}

model UserSession {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  sessionToken   String   @map("session_token")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    String?  @map("user_id") @db.Uuid
  action    String
  entityId  String?  @map("entity_id") @db.Uuid
  recordId  String?  @map("record_id") @db.Uuid
  fieldName String?  @map("field_name")
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model AccessLog {
  id                BigInt   @id @default(autoincrement())
  userId            String?  @map("user_id") @db.Uuid
  endpoint          String
  method            String
  statusCode        Int      @map("status_code")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  requestDurationMs Int?     @map("request_duration_ms")
  requestSize       Int?     @map("request_size")
  responseSize      Int?     @map("response_size")
  createdAt         DateTime @default(now()) @map("created_at")
  user              User?    @relation(fields: [userId], references: [id])

  @@map("access_logs")
}

model Entity {
  id          String         @id @default(uuid()) @db.Uuid
  code        String         @unique
  name        String
  description String?
  config      Json?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  records     EntityRecord[]

  @@map("entities")
}

model EntityRecord {
  id                String                 @id @default(uuid()) @db.Uuid
  entityId          String                 @map("entity_id") @db.Uuid
  data              Json
  createdBy         String?                @map("created_by") @db.Uuid
  updatedBy         String?                @map("updated_by") @db.Uuid
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  deletedAt         DateTime?              @map("deleted_at")
  bomLines          BillOfMaterialLine[]
  entity            Entity                 @relation(fields: [entityId], references: [id], onDelete: Cascade)
  industrialMeta    ProductIndustrialMeta?
  linkedCoreProduct Product?

  @@index([entityId], map: "idx_entity_records_entity")
  @@map("entity_records")
}

/// Metadados industriais (BOM status, modelo 3D) ligados ao registro de produto (entidade `produto`).
model ProductIndustrialMeta {
  entityRecordId      String       @id @map("entity_record_id") @db.Uuid
  bomStatus           String       @default("EMPTY") @map("bom_status")
  model3dPath         String?      @map("model3d_path")
  model3dOriginalName String?      @map("model3d_original_name")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  entityRecord        EntityRecord @relation(fields: [entityRecordId], references: [id], onDelete: Cascade)

  @@map("product_industrial_meta")
}

/// Linhas de lista de materiais (produto pai = registro entity `produto`).
model BillOfMaterialLine {
  id              String       @id @default(uuid()) @db.Uuid
  productRecordId String       @map("product_record_id") @db.Uuid
  lineOrder       Int          @default(0) @map("line_order")
  componentCode   String       @map("component_code")
  description     String?
  materialSpec    String?      @map("material_spec")
  /// Processo produtivo: ALMOXARIFADO, LASER, DOBRA, SOLDADO, USINAGEM, PINTURA, MONTAGEM, etc.
  process         String?      @map("process")
  xMm             Float?       @map("x_mm")
  yMm             Float?       @map("y_mm")
  thicknessMm     Float?       @map("thickness_mm")
  weightKg        Float?       @map("weight_kg")
  quantity        Float        @default(1)
  totalQty        Float?       @map("total_qty")
  createdAt       DateTime     @default(now()) @map("created_at")
  productRecord   EntityRecord @relation(fields: [productRecordId], references: [id], onDelete: Cascade)

  @@index([productRecordId], map: "idx_bom_lines_product")
  @@map("bill_of_material_lines")
}

/// Matérias-primas / blanks criados automaticamente ou cadastrados (catálogo industrial).
model RawMaterial {
  id                   String   @id @default(uuid()) @db.Uuid
  code                 String   @unique
  name                 String
  materialCode         String?  @map("material_code")
  materialType         String?  @map("material_type")
  unit                 String?  @default("un")
  dimensionsX          Float?   @map("dimensions_x")
  dimensionsY          Float?   @map("dimensions_y")
  thickness            Float?
  weightKg             Float?   @map("weight_kg")
  supplierDefault      String   @default("A definir") @map("supplier_default")
  linkedEntityRecordId String?  @unique @map("linked_entity_record_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("raw_materials")
}

model TechnicalFile {
  id              String   @id @default(uuid()) @db.Uuid
  productRecordId String?  @map("product_record_id") @db.Uuid
  opRecordId      String?  @map("op_record_id") @db.Uuid
  tipo            String
  nomeOriginal    String   @map("nome_original")
  caminhoArquivo  String   @map("caminho_arquivo")
  uploadedBy      String?  @map("uploaded_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([productRecordId], map: "idx_technical_files_product")
  @@index([opRecordId], map: "idx_technical_files_op")
  @@map("technical_files")
}

model DashboardLayout {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  widgets   Json     @default("[]")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dashboard_layouts")
}

model UserNotification {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  sector       String?   @map("sector")
  type         String    @default("info")
  text         String
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  /// * Lista JSON de códigos de role que devem ver a notificação (filtro no backend).
  targetRoles  Json?     @map("target_roles")
  targetModule String?   @map("target_module")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt], map: "idx_user_notifications_user_read")
  @@index([userId, sector], map: "idx_user_notifications_user_sector")
  @@map("user_notifications")
}

model Location {
  id               String               @id @default(uuid()) @db.Uuid
  code             String               @unique
  name             String
  warehouse        String?              @map("warehouse")
  aisle            String?
  rack             String?
  bin              String?
  active           Boolean              @default(true)
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  inventoryItems   InventoryCountItem[]
  productLocations ProductLocation[]
  stockMovements   StockMovement[]

  @@map("locations")
}

model Product {
  id                 String               @id @default(uuid()) @db.Uuid
  code               String               @unique
  name               String
  description        String?
  unit               String               @default("UN")
  productType        String?              @map("product_type")
  group              String?
  costPrice          Decimal?             @map("cost_price") @db.Decimal(14, 4)
  salePrice          Decimal?             @map("sale_price") @db.Decimal(14, 4)
  minStock           Decimal              @default(0) @map("min_stock") @db.Decimal(14, 4)
  reorderPoint       Decimal?             @map("reorder_point") @db.Decimal(14, 4)
  status             String               @default("Ativo")
  photoUrl           String?              @map("photo_url")
  techSheet          String?              @map("tech_sheet")
  /// * Caminho do modelo 3D (atalho; detalhe também em product_industrial_meta).
  model3dPath        String?              @map("model3d_path")
  entityRecordId     String?              @unique @map("entity_record_id") @db.Uuid
  companyId          String               @map("company_id")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  company            Company              @relation(fields: [companyId], references: [id])
  inventoryItems     InventoryCountItem[]
  priceTableItems    PriceTableItem[]
  productFiles       ProductFile[]
  locations          ProductLocation[]
  entityRecord       EntityRecord?        @relation(fields: [entityRecordId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  quoteItems         QuoteItem[]
  routings           Routing[]
  saleOrderItems     SaleOrderItem[]
  stockMovements     StockMovement[]
  workOrderItems     WorkOrderItem[]
  workOrdersMain     WorkOrder[]          @relation("WorkOrderFinishedProduct")

  @@map("products")
}

model ProductLocation {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  quantity   Decimal  @default(0) @db.Decimal(14, 4)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId], map: "uq_product_location")
  @@map("product_locations")
}

model StockMovement {
  id         String            @id @default(uuid()) @db.Uuid
  productId  String            @map("product_id") @db.Uuid
  locationId String?           @map("location_id") @db.Uuid
  type       StockMovementType
  quantity   Decimal           @db.Decimal(14, 4)
  reference  String?
  notes      String?
  userId     String?           @map("user_id") @db.Uuid
  createdAt  DateTime          @default(now()) @map("created_at")
  location   Location?         @relation(fields: [locationId], references: [id])
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User?             @relation(fields: [userId], references: [id])

  @@index([productId, createdAt], map: "idx_stock_movements_product_created")
  @@map("stock_movements")
}

model InventoryCount {
  id           String               @id @default(uuid()) @db.Uuid
  code         String               @unique
  status       InventoryCountStatus @default(RASCUNHO)
  notes        String?
  approvedAt   DateTime?            @map("approved_at")
  approvedById String?              @map("approved_by_id") @db.Uuid
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  items        InventoryCountItem[]
  approvedBy   User?                @relation("InventoryCountApprovedBy", fields: [approvedById], references: [id])

  @@map("inventory_counts")
}

model InventoryCountItem {
  id               String         @id @default(uuid()) @db.Uuid
  inventoryCountId String         @map("inventory_count_id") @db.Uuid
  productId        String         @map("product_id") @db.Uuid
  locationId       String?        @map("location_id") @db.Uuid
  qtySystem        Decimal        @map("qty_system") @db.Decimal(14, 4)
  qtyCounted       Decimal?       @map("qty_counted") @db.Decimal(14, 4)
  inventoryCount   InventoryCount @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  location         Location?      @relation(fields: [locationId], references: [id])
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([inventoryCountId], map: "idx_inventory_count_items_parent")
  @@map("inventory_count_items")
}

model Customer {
  id            String             @id @default(uuid()) @db.Uuid
  code          String             @unique
  name          String
  document      String?            @map("document")
  email         String?
  phone         String?
  address       String?
  active        Boolean            @default(true)
  companyId     String             @map("company_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  company       Company            @relation(fields: [companyId], references: [id])
  quotes        Quote[]
  saleOrders    SaleOrder[]
  opportunities SalesOpportunity[]

  @@map("customers")
}

/// Funil comercial (pré-orçamento) — qualificação e rastreio.
model SalesOpportunity {
  id            String          @id @default(uuid()) @db.Uuid
  number        String          @unique
  customerId    String          @map("customer_id") @db.Uuid
  ownerUserId   String?         @map("owner_user_id") @db.Uuid
  companyId     String          @map("company_id")
  title         String
  /// LEAD | QUALIFYING | PROPOSAL | WON | LOST | NURTURE | DISCARDED
  status        String          @default("LEAD")
  profileAbc    String?         @map("profile_abc")
  projectType   String?         @map("project_type")
  potential     String?
  scopeNotes    String?         @map("scope_notes")
  deliveryNotes String?         @map("delivery_notes")
  lostReason    String?         @map("lost_reason")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  quotes        Quote[]
  activities    SalesActivity[]
  customer      Customer        @relation(fields: [customerId], references: [id])
  owner         User?           @relation("OpportunityOwner", fields: [ownerUserId], references: [id])
  company       Company         @relation(fields: [companyId], references: [id])

  @@index([customerId], map: "idx_opportunities_customer")
  @@index([ownerUserId], map: "idx_opportunities_owner")
  @@index([status], map: "idx_opportunities_status")
  @@map("sales_opportunities")
}

/// Linha do tempo: notas, ligação, e-mail, mudança de status.
model SalesActivity {
  id            String            @id @default(uuid()) @db.Uuid
  opportunityId String?           @map("opportunity_id") @db.Uuid
  quoteId       String?           @map("quote_id") @db.Uuid
  userId        String?           @map("user_id") @db.Uuid
  type          String
  body          String
  metadata      Json?
  createdAt     DateTime          @default(now()) @map("created_at")
  opportunity   SalesOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  quote         Quote?            @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  user          User?             @relation(fields: [userId], references: [id])

  @@index([opportunityId], map: "idx_sales_act_opp")
  @@index([quoteId], map: "idx_sales_act_quote")
  @@map("sales_activities")
}

model Quote {
  id              String            @id @default(uuid()) @db.Uuid
  number          String            @unique
  customerId      String            @map("customer_id") @db.Uuid
  status          QuoteStatus       @default(RASCUNHO)
  validUntil      DateTime?         @map("valid_until")
  notes           String?
  totalAmount     Decimal?          @map("total_amount") @db.Decimal(14, 2)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  /// * Vínculo opcional ao funil comercial
  opportunityId   String?           @map("opportunity_id") @db.Uuid
  /// * Mesmo UUID em todas as versões da proposta (V1, V2…)
  familyId        String            @map("family_id") @db.Uuid
  versionNumber   Int               @default(1) @map("version_number")
  /// * Preenchido ao converter em PV — bloqueia edição
  lockedAt        DateTime?         @map("locked_at")
  /// * NOT_REQUIRED | PENDING | APPROVED | NEEDS_ADJUSTMENT
  technicalReview String            @default("NOT_REQUIRED") @map("technical_review")
  items           QuoteItem[]
  customer        Customer          @relation(fields: [customerId], references: [id])
  opportunity     SalesOpportunity? @relation(fields: [opportunityId], references: [id])
  saleOrder       SaleOrder?
  activities      SalesActivity[]

  @@index([opportunityId], map: "idx_quotes_opportunity")
  @@index([familyId], map: "idx_quotes_family")
  @@map("quotes")
}

model QuoteItem {
