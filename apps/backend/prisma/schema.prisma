model NcMetaCodeRule {
  id                   String               @id @default(uuid()) @db.Uuid
  /// produto | pedido_venda | ordem_producao | work_order | …
  entity               String               @unique @db.VarChar(64)
  prefix               String               @db.VarChar(16)
  /// Nome do campo no JSON/registo usado para resolver a sigla (ex.: categoria_industrial, group).
  categoriaField       String?              @map("categoria_field") @db.VarChar(64)
  useYear              Boolean              @default(true) @map("use_year")
  useMonth             Boolean              @default(true) @map("use_month")
  sequencePadding      Int                  @default(5) @map("sequence_padding")
  /// year | month | never
  resetType            String               @default("month") @map("reset_type") @db.VarChar(16)
  /// CAT_PREFIX_YM_SEQ | PREFIX_CAT_YM_SEQ | PREFIX_YEAR_SEQ
  format               String               @default("PREFIX_CAT_YM_SEQ") @db.VarChar(32)
  /// codigo | numero | number (work_orders.number)
  targetField          String               @default("numero") @map("target_field") @db.VarChar(32)
  fallbackCategoryCode String               @default("MOB") @map("fallback_category_code") @db.VarChar(16)
  active               Boolean              @default(true)
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  sequences            NcMetaCodeSequence[]

  @@map("nc_meta_code_rules")
}

model NcMetaCodeSequence {
  id          String         @id @default(uuid()) @db.Uuid
  ruleId      String         @map("rule_id") @db.Uuid
  periodKey   String         @map("period_key") @db.VarChar(32)
  categoryKey String         @map("category_key") @db.VarChar(32)
  lastValue   Int            @map("last_value")
  rule        NcMetaCodeRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, periodKey, categoryKey], map: "uq_nc_meta_code_sequence")
  @@map("nc_meta_code_sequences")
}

