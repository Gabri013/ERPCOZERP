/// Ordem de produção (catálogo Prisma + integração vendas).
model WorkOrder {
  id                String                   @id @default(uuid()) @db.Uuid
  number            String                   @unique
  status            String                   @default("DRAFT")
  saleOrderId       String?                  @map("sale_order_id") @db.Uuid
  productId         String?                  @map("product_id") @db.Uuid
  routingId         String?                  @map("routing_id") @db.Uuid
  quantityPlanned   Decimal                  @default(1) @map("quantity_planned") @db.Decimal(14, 4)
  scheduledStart    DateTime?                @map("scheduled_start")
  scheduledEnd      DateTime?                @map("scheduled_end")
  dueDate           DateTime?                @map("due_date")
  kanbanColumn      String                   @default("BACKLOG") @map("kanban_column")
  kanbanOrder       Int                      @default(0) @map("kanban_order")
  priority          String                   @default("normal")
  /// Sigla industrial (COC, REF, MOB) para badge/cor — preenchido na geração do código.
  categoryCode      String?                  @map("category_code") @db.VarChar(16)
  categoryLabel     String?                  @map("category_label") @db.VarChar(128)
  notes             String?
  responsibleUserId String?                  @map("responsible_user_id") @db.Uuid
  companyId         String                  @map("company_id")
  finishedAt        DateTime?                @map("finished_at")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  appointments      ProductionAppointment[]
  items             WorkOrderItem[]
  statusHistory     WorkOrderStatusHistory[]
  product           Product?                 @relation("WorkOrderFinishedProduct", fields: [productId], references: [id])
  responsible       User?                    @relation("WorkOrderResponsible", fields: [responsibleUserId], references: [id])
  routing           Routing?                 @relation(fields: [routingId], references: [id])
  saleOrder         SaleOrder?               @relation(fields: [saleOrderId], references: [id])
  company           Company                  @relation(fields: [companyId], references: [id])

  @@index([saleOrderId], map: "idx_work_orders_sale_order")
  @@index([status], map: "idx_work_orders_status")
  @@index([kanbanColumn], map: "idx_work_orders_kanban_col")
  @@map("work_orders")
}

