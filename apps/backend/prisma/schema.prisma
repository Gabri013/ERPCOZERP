generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String     @id @default(uuid()) @db.Uuid
  /** Id do usuário no banco legado (MySQL/MariaDB), para migração idempotente */
  legacyId            Int?       @unique @map("legacy_id")
  email               String     @unique
  passwordHash        String     @map("password_hash")
  fullName            String     @map("full_name")
  active              Boolean    @default(true)
  emailVerified       Boolean    @default(false) @map("email_verified")
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  lastLoginAt         DateTime?  @map("last_login_at")
  /** Setor operacional (ex.: Expedição, Corte Laser); opcional — usado para dashboards e filtros */
  sector              String?    @map("sector")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  roles     UserRole[]
  sessions  UserSession[]
  auditLogs AuditLog[]
  accessLogs AccessLog[]
  dashboardLayout DashboardLayout?
  notifications UserNotification[]
  stockMovements           StockMovement[]
  approvedInventoryCounts  InventoryCount[] @relation("InventoryCountApprovedBy")
  approvedSaleOrders       SaleOrder[]      @relation("SaleOrderApprovedBy")
  responsibleWorkOrders    WorkOrder[]      @relation("WorkOrderResponsible")
  workOrderStatusHistory   WorkOrderStatusHistory[]
  employeeProfile        Employee?

  @@map("users")
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique
  name        String
  description String?
  active      Boolean @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique
  name        String
  category    String
  description String?
  type        String  @default("action")
  active      Boolean @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedBy String?  @map("assigned_by") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId], map: "uq_user_role")
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  granted      Boolean  @default(true)
  conditions   Json?
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId], map: "uq_role_permission")
  @@map("role_permissions")
}

model UserSession {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  sessionToken   String   @map("session_token")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model AuditLog {
  id               BigInt   @id @default(autoincrement())
  userId           String?  @map("user_id") @db.Uuid
  action           String
  entityId         String?  @map("entity_id") @db.Uuid
  recordId         String?  @map("record_id") @db.Uuid
  fieldName        String?  @map("field_name")
  oldValue         String?  @map("old_value")
  newValue         String?  @map("new_value")
  ipAddress        String?  @map("ip_address")
  userAgent        String?  @map("user_agent")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model AccessLog {
  id                BigInt   @id @default(autoincrement())
  userId            String?  @map("user_id") @db.Uuid
  endpoint          String
  method            String
  statusCode        Int      @map("status_code")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  requestDurationMs Int?     @map("request_duration_ms")
  requestSize       Int?     @map("request_size")
  responseSize      Int?     @map("response_size")
  createdAt         DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("access_logs")
}

model Entity {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String
  description String?
  config      Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  records EntityRecord[]

  @@map("entities")
}

model EntityRecord {
  id        String   @id @default(uuid()) @db.Uuid
  entityId  String   @map("entity_id") @db.Uuid
  data      Json
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  industrialMeta ProductIndustrialMeta?
  bomLines     BillOfMaterialLine[]
  linkedCoreProduct Product?

  @@index([entityId], map: "idx_entity_records_entity")
  @@map("entity_records")
}

/// Metadados industriais (BOM status, modelo 3D) ligados ao registro de produto (entidade `produto`).
model ProductIndustrialMeta {
  entityRecordId String   @id @map("entity_record_id") @db.Uuid
  entityRecord   EntityRecord @relation(fields: [entityRecordId], references: [id], onDelete: Cascade)
  bomStatus      String   @default("EMPTY") @map("bom_status")
  model3dPath    String?  @map("model3d_path")
  model3dOriginalName String? @map("model3d_original_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("product_industrial_meta")
}

/// Linhas de lista de materiais (produto pai = registro entity `produto`).
model BillOfMaterialLine {
  id              String   @id @default(uuid()) @db.Uuid
  productRecordId String   @map("product_record_id") @db.Uuid
  productRecord   EntityRecord @relation(fields: [productRecordId], references: [id], onDelete: Cascade)
  lineOrder       Int      @default(0) @map("line_order")
  componentCode   String   @map("component_code")
  description     String?  @db.Text
  materialSpec    String?  @map("material_spec") @db.Text
  /// Processo produtivo: ALMOXARIFADO, LASER, DOBRA, SOLDADO, USINAGEM, PINTURA, MONTAGEM, etc.
  process         String?  @map("process")
  xMm             Float?   @map("x_mm")
  yMm             Float?   @map("y_mm")
  thicknessMm     Float?   @map("thickness_mm")
  weightKg        Float?   @map("weight_kg")
  quantity        Float    @default(1)
  totalQty        Float?   @map("total_qty")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([productRecordId], map: "idx_bom_lines_product")
  @@map("bill_of_material_lines")
}

/// Matérias-primas / blanks criados automaticamente ou cadastrados (catálogo industrial).
model RawMaterial {
  id                   String   @id @default(uuid()) @db.Uuid
  code                 String   @unique
  name                 String
  materialCode         String?  @map("material_code") @db.Text
  materialType         String?  @map("material_type")
  unit                 String?  @default("un")
  dimensionsX          Float?   @map("dimensions_x")
  dimensionsY          Float?   @map("dimensions_y")
  thickness            Float?
  weightKg             Float?   @map("weight_kg")
  supplierDefault      String   @default("A definir") @map("supplier_default")
  linkedEntityRecordId String?  @unique @map("linked_entity_record_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("raw_materials")
}

model TechnicalFile {
  id              String   @id @default(uuid()) @db.Uuid
  productRecordId String?  @map("product_record_id") @db.Uuid
  opRecordId      String?  @map("op_record_id") @db.Uuid
  tipo            String
  nomeOriginal    String   @map("nome_original")
  caminhoArquivo  String   @map("caminho_arquivo")
  uploadedBy      String?  @map("uploaded_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([productRecordId], map: "idx_technical_files_product")
  @@index([opRecordId], map: "idx_technical_files_op")
  @@map("technical_files")
}

model DashboardLayout {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  widgets   Json     @default("[]")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dashboard_layouts")
}

model UserNotification {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  sector       String?   @map("sector")
  type         String    @default("info")
  text         String
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  /** Lista JSON de códigos de role que devem ver a notificação (filtro no backend). */
  targetRoles  Json?     @map("target_roles")
  targetModule String?   @map("target_module")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt], map: "idx_user_notifications_user_read")
  @@index([userId, sector], map: "idx_user_notifications_user_sector")
  @@map("user_notifications")
}

// --- Módulo 1: produtos, estoque físico, inventário, endereços ---

enum StockMovementType {
  ENTRADA
  SAIDA
  AJUSTE
}

enum InventoryCountStatus {
  RASCUNHO
  EM_CONTAGEM
  APROVADO
}

model Location {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique
  name       String
  warehouse  String?  @map("warehouse")
  aisle      String?
  rack       String?
  bin        String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  productLocations ProductLocation[]
  stockMovements   StockMovement[]
  inventoryItems   InventoryCountItem[]

  @@map("locations")
}

model Product {
  id               String   @id @default(uuid()) @db.Uuid
  code             String   @unique
  name             String
  description      String?  @db.Text
  unit             String   @default("UN")
  productType      String?  @map("product_type")
  group            String?
  costPrice        Decimal? @map("cost_price") @db.Decimal(14, 4)
  salePrice        Decimal? @map("sale_price") @db.Decimal(14, 4)
  minStock         Decimal  @default(0) @map("min_stock") @db.Decimal(14, 4)
  reorderPoint     Decimal? @map("reorder_point") @db.Decimal(14, 4)
  status           String   @default("Ativo")
  photoUrl         String?  @map("photo_url")
  techSheet        String?  @map("tech_sheet") @db.Text
  /** Caminho do modelo 3D (atalho; detalhe também em product_industrial_meta). */
  model3dPath      String?  @map("model3d_path")
  entityRecordId   String?  @unique @map("entity_record_id") @db.Uuid

  entityRecord     EntityRecord?      @relation(fields: [entityRecordId], references: [id], onDelete: SetNull)
  locations        ProductLocation[]
  stockMovements   StockMovement[]
  inventoryItems   InventoryCountItem[]
  workOrderItems   WorkOrderItem[]
  saleOrderItems   SaleOrderItem[]
  quoteItems       QuoteItem[]
  priceTableItems  PriceTableItem[]
  purchaseOrderItems PurchaseOrderItem[]
  routings           Routing[]
  workOrdersMain     WorkOrder[]       @relation("WorkOrderFinishedProduct")
  productFiles       ProductFile[]

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model ProductLocation {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  locationId String   @map("location_id") @db.Uuid
  quantity   Decimal  @default(0) @db.Decimal(14, 4)

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId], map: "uq_product_location")
  @@map("product_locations")
}

model StockMovement {
  id          String            @id @default(uuid()) @db.Uuid
  productId   String            @map("product_id") @db.Uuid
  locationId  String?           @map("location_id") @db.Uuid
  type        StockMovementType
  quantity    Decimal           @db.Decimal(14, 4)
  reference   String?
  notes       String?           @db.Text
  userId      String?           @map("user_id") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at")

  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  location    Location?         @relation(fields: [locationId], references: [id], onDelete: SetNull)
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt], map: "idx_stock_movements_product_created")
  @@map("stock_movements")
}

model InventoryCount {
  id            String               @id @default(uuid()) @db.Uuid
  code          String               @unique
  status        InventoryCountStatus   @default(RASCUNHO)
  notes         String?              @db.Text
  approvedAt    DateTime?            @map("approved_at")
  approvedById  String?              @map("approved_by_id") @db.Uuid
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  items         InventoryCountItem[]
  approvedBy    User?                @relation("InventoryCountApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@map("inventory_counts")
}

model InventoryCountItem {
  id               String   @id @default(uuid()) @db.Uuid
  inventoryCountId String   @map("inventory_count_id") @db.Uuid
  productId        String   @map("product_id") @db.Uuid
  locationId       String?  @map("location_id") @db.Uuid
  qtySystem        Decimal  @map("qty_system") @db.Decimal(14, 4)
  qtyCounted       Decimal? @map("qty_counted") @db.Decimal(14, 4)

  inventoryCount   InventoryCount @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  location         Location?      @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([inventoryCountId], map: "idx_inventory_count_items_parent")
  @@map("inventory_count_items")
}

// --- Vendas (catálogo relacional) ---
model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  document  String?  @map("document")
  email     String?
  phone     String?
  address   String?  @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  saleOrders SaleOrder[]
  quotes     Quote[]

  @@map("customers")
}

enum QuoteStatus {
  RASCUNHO
  ENVIADO
  CONVERTIDO
  CANCELADO
}

model Quote {
  id         String      @id @default(uuid()) @db.Uuid
  number     String      @unique
  customerId String      @map("customer_id") @db.Uuid
  status     QuoteStatus @default(RASCUNHO)
  validUntil DateTime?   @map("valid_until")
  notes      String?     @db.Text
  totalAmount Decimal?   @map("total_amount") @db.Decimal(14, 2)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items      QuoteItem[]
  saleOrder  SaleOrder?

  @@map("quotes")
}

model QuoteItem {
  id          String   @id @default(uuid()) @db.Uuid
  quoteId     String   @map("quote_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  quantity    Decimal  @db.Decimal(14, 4)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(14, 4)
  discountPct Decimal? @map("discount_pct") @db.Decimal(5, 2)

  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([quoteId], map: "idx_quote_items_quote")
  @@map("quote_items")
}

model PriceTable {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique
  name      String
  currency  String    @default("BRL")
  active    Boolean   @default(true)
  validFrom DateTime? @map("valid_from")
  validTo   DateTime? @map("valid_to")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  items PriceTableItem[]

  @@map("price_tables")
}

model PriceTableItem {
  id           String   @id @default(uuid()) @db.Uuid
  priceTableId String   @map("price_table_id") @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  price        Decimal  @db.Decimal(14, 4)
  minQty       Decimal? @map("min_qty") @db.Decimal(14, 4)

  priceTable PriceTable @relation(fields: [priceTableId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([priceTableId, productId], map: "uq_price_table_product")
  @@map("price_table_items")
}

/// Ordens de venda (PV-AAAA-#####).
model SaleOrder {
  id             String    @id @default(uuid()) @db.Uuid
  number         String    @unique
  customerId     String?   @map("customer_id") @db.Uuid
  quoteId        String?   @unique @map("quote_id") @db.Uuid
  status         String    @default("DRAFT")
  kanbanColumn   String    @default("PEDIDO") @map("kanban_column")
  kanbanOrder    Int       @default(0) @map("kanban_order")
  orderDate      DateTime  @default(now()) @map("order_date")
  deliveryDate   DateTime? @map("delivery_date")
  notes          String?   @db.Text
  totalAmount    Decimal?  @map("total_amount") @db.Decimal(14, 2)
  approvedAt     DateTime? @map("approved_at")
  approvedById   String?   @map("approved_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  quote       Quote?       @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  approvedBy  User?        @relation("SaleOrderApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  workOrders  WorkOrder[]
  items       SaleOrderItem[]

  @@index([status], map: "idx_sale_orders_status")
  @@map("sale_orders")
}

model SaleOrderItem {
  id          String   @id @default(uuid()) @db.Uuid
  saleOrderId String   @map("sale_order_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  quantity    Decimal  @db.Decimal(14, 4)
  unitPrice   Decimal  @default(0) @map("unit_price") @db.Decimal(14, 4)
  discountPct Decimal? @map("discount_pct") @db.Decimal(5, 2)
  lineTotal   Decimal  @default(0) @map("line_total") @db.Decimal(14, 2)

  saleOrder SaleOrder @relation(fields: [saleOrderId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("sale_order_items")
}

/// Ordem de produção (catálogo Prisma + integração vendas).
model WorkOrder {
  id                  String    @id @default(uuid()) @db.Uuid
  number              String    @unique
  status              String    @default("DRAFT")
  saleOrderId         String?   @map("sale_order_id") @db.Uuid
  productId           String?   @map("product_id") @db.Uuid
  routingId           String?   @map("routing_id") @db.Uuid
  quantityPlanned     Decimal   @default(1) @map("quantity_planned") @db.Decimal(14, 4)
  scheduledStart      DateTime? @map("scheduled_start")
  scheduledEnd        DateTime? @map("scheduled_end")
  dueDate             DateTime? @map("due_date")
  kanbanColumn        String    @default("BACKLOG") @map("kanban_column")
  kanbanOrder         Int       @default(0) @map("kanban_order")
  priority            String    @default("normal")
  notes               String?   @db.Text
  responsibleUserId   String?   @map("responsible_user_id") @db.Uuid
  finishedAt          DateTime? @map("finished_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  saleOrder    SaleOrder?                @relation(fields: [saleOrderId], references: [id], onDelete: SetNull)
  product      Product?                  @relation("WorkOrderFinishedProduct", fields: [productId], references: [id], onDelete: SetNull)
  routing      Routing?                  @relation(fields: [routingId], references: [id], onDelete: SetNull)
  responsible  User?                     @relation("WorkOrderResponsible", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  items        WorkOrderItem[]
  statusHistory WorkOrderStatusHistory[]
  appointments ProductionAppointment[]

  @@index([saleOrderId], map: "idx_work_orders_sale_order")
  @@index([status], map: "idx_work_orders_status")
  @@index([kanbanColumn], map: "idx_work_orders_kanban_col")
  @@map("work_orders")
}

model Machine {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  sector    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  routingStages RoutingStage[]
  appointments  ProductionAppointment[]

  @@map("machines")
}

model Routing {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  productId String?  @map("product_id") @db.Uuid
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product    Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  stages     RoutingStage[]
  workOrders WorkOrder[]

  @@map("routings")
}

model RoutingStage {
  id              String   @id @default(uuid()) @db.Uuid
  routingId       String   @map("routing_id") @db.Uuid
  sortOrder       Int      @default(0) @map("sort_order")
  name            String
  machineId       String?  @map("machine_id") @db.Uuid
  durationMinutes Int?     @map("duration_minutes")

  routing       Routing                 @relation(fields: [routingId], references: [id], onDelete: Cascade)
  machine       Machine?                @relation(fields: [machineId], references: [id], onDelete: SetNull)
  appointments  ProductionAppointment[]

  @@index([routingId], map: "idx_routing_stages_routing")
  @@map("routing_stages")
}

model WorkOrderStatusHistory {
  id          String   @id @default(uuid()) @db.Uuid
  workOrderId String   @map("work_order_id") @db.Uuid
  fromStatus  String?  @map("from_status")
