  laborCost    Decimal  @default(0) @map("labor_cost") @db.Decimal(14, 4)
  overheadCost Decimal  @default(0) @map("overhead_cost") @db.Decimal(14, 4)
  totalCost    Decimal  @default(0) @map("total_cost") @db.Decimal(14, 4)
  salePrice    Decimal? @map("sale_price") @db.Decimal(14, 4)
  marginPct    Decimal? @map("margin_pct") @db.Decimal(5, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("product_standard_costs")
}

